  ipset_file: {{ adguard_dns_ipset_file | to_json }}
  bootstrap_prefer_ipv6: {{ adguard_dns_bootstrap_prefer_ipv6 | to_json }}
  upstream_timeout: {{ adguard_dns_upstream_timeout | to_json }}
  private_networks: {{ adguard_dns_private_networks | to_json }}
  use_private_ptr_resolvers: {{ adguard_dns_use_private_ptr_resolvers | to_json }}
  local_ptr_upstreams: {{ adguard_dns_local_ptr_upstreams | to_json }}
  use_dns64: {{ adguard_dns_use_dns64 | to_json }}
  dns64_prefixes: {{ adguard_dns_dns64_prefixes | to_json }}
