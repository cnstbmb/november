global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

scrape_configs:
  - job_name: public_status
    metrics_path: /federate
    params:
      'match[]':
        - '{__name__=~"public_.*"}'
    static_configs:
      - targets:
          - "prometheus:9090"
