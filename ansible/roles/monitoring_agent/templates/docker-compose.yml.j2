services:
  node_exporter:
    image: {{ monitoring_node_exporter_image }}
    restart: unless-stopped
    network_mode: host
    command:
      - "--path.procfs=/host/proc"
      - "--path.rootfs=/rootfs"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc|run|snap)($|/)"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro,rslave

  promtail:
    image: {{ monitoring_promtail_image }}
    restart: unless-stopped
    command:
      - "-config.file=/etc/promtail/config.yml"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./promtail-config.yml:/etc/promtail/config.yml:ro
      - promtail-positions:/positions
      - /var/log:/var/log:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro

volumes:
  promtail-positions:
