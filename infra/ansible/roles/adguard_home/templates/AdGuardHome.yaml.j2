  dir_path: {{ adguard_statistics_dir_path | to_json }}
  ignored: {{ adguard_statistics_ignored | to_json }}
  interval: {{ adguard_statistics_interval | to_json }}
  enabled: {{ adguard_statistics_enabled | to_json }}
  ignored_enabled: {{ adguard_statistics_ignored_enabled | to_json }}
filters: {{ adguard_filters | to_json }}
whitelist_filters: {{ adguard_whitelist_filters | to_json }}
user_rules: {{ adguard_user_rules | to_json }}
dhcp:
  enabled: {{ adguard_dhcp_enabled | to_json }}
  interface_name: {{ adguard_dhcp_interface_name | to_json }}
  local_domain_name: {{ adguard_dhcp_local_domain_name | to_json }}
  dhcpv4: {{ adguard_dhcpv4 | to_json }}
  dhcpv6: {{ adguard_dhcpv6 | to_json }}
filtering:
  blocking_ipv4: {{ adguard_filtering_blocking_ipv4 | to_json }}
  blocking_ipv6: {{ adguard_filtering_blocking_ipv6 | to_json }}
  blocked_services:
    schedule:
