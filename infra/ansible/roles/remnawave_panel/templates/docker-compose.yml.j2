x-common: &common
  restart: always
  ulimits:
    nofile:
      soft: 1048576
      hard: 1048576

x-logging: &logging
  logging:
    driver: json-file
    options:
      max-size: 100m
      max-file: 5

x-env: &env
  env_file: .env

services:
  remnawave-proxy:
    image: nginx:mainline-alpine
    container_name: {{ remnawave_panel_proxy_container_name_effective }}
    restart: unless-stopped
    depends_on:
      - remnawave
{% if remnawave_subscription_page_enabled_effective %}
      - remnawave-subscription-page
{% endif %}
    ports:
      - "{{ remnawave_panel_http_port_effective }}:80"
{% for https_port in remnawave_panel_https_ports_effective %}
      - "{{ https_port }}:443"
{% endfor %}
{% if remnawave_panel_xhttp_proxy_locations_effective | length > 0 %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    volumes:
      - "{{ remnawave_panel_nginx_conf_file_effective }}:/etc/nginx/conf.d/default.conf:ro"
{% if remnawave_panel_landing_enabled_effective %}
      - "{{ remnawave_panel_landing_dest_dir_effective }}:/usr/share/nginx/html:ro"
{% endif %}
{% if remnawave_subscription_page_enabled_effective %}
      - "{{ remnawave_subscription_page_static_dest_dir_effective }}:/usr/share/nginx/subscription-page:ro"
{% endif %}
      - /etc/letsencrypt:/etc/letsencrypt:ro
    networks:
      - default
      - remnawave-network

  remnawave:
    image: "{{ remnawave_panel_image | default('remnawave/backend:2') }}"
    container_name: remnawave
    hostname: remnawave
    <<: [*common, *logging, *env]
    expose:
      - "{{ remnawave_panel_app_port_effective }}"
      - "{{ remnawave_panel_metrics_port_effective }}"
    networks:
      - default
      - remnawave-network
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:${METRICS_PORT:-3001}/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    depends_on:
      remnawave-db:
        condition: service_healthy
      remnawave-redis:
        condition: service_healthy
{% if remnawave_subscription_page_enabled_effective %}

  remnawave-subscription-page:
    image: "{{ remnawave_subscription_page_image | default('remnawave/subscription-page:latest') }}"
    container_name: {{ remnawave_subscription_page_container_name_effective }}
    hostname: {{ remnawave_subscription_page_container_name_effective }}
    <<: [*common, *logging]
    env_file:
      - "{{ remnawave_subscription_page_env_file_effective }}"
    expose:
      - "{{ remnawave_subscription_page_app_port_effective }}"
    depends_on:
      - remnawave
{% endif %}

  remnawave-db:
    image: "{{ remnawave_panel_postgres_image | default('postgres:17.6') }}"
    container_name: remnawave-db
    hostname: remnawave-db
    <<: [*common, *logging, *env]
    environment:
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - POSTGRES_DB=${POSTGRES_DB}
      - TZ=UTC
    volumes:
      - remnawave-db-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 3s
      timeout: 10s
      retries: 3

  remnawave-redis:
    image: "{{ remnawave_panel_redis_image | default('valkey/valkey:8.1-alpine') }}"
    container_name: remnawave-redis
    hostname: remnawave-redis
    <<: [*common, *logging]
    command: >
      valkey-server
      --save ""
      --appendonly no
      --maxmemory-policy noeviction
      --loglevel warning
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 3s
      timeout: 3s
      retries: 3

networks:
  default:
    name: "{{ remnawave_panel_project_name_effective }}-internal"
    driver: bridge
  remnawave-network:
    name: "{{ remnawave_network_name | default('remnawave-network') }}"
    external: true

volumes:
  remnawave-db-data:
    name: "{{ remnawave_panel_project_name_effective }}-db-data"
