  port: {{ adguard_dns_port }}
  anonymize_client_ip: {{ adguard_dns_anonymize_client_ip | to_json }}
  ratelimit: {{ adguard_dns_ratelimit }}
  ratelimit_subnet_len_ipv4: {{ adguard_dns_ratelimit_subnet_len_ipv4 }}
  ratelimit_subnet_len_ipv6: {{ adguard_dns_ratelimit_subnet_len_ipv6 }}
  ratelimit_whitelist: {{ adguard_dns_ratelimit_whitelist | to_json }}
  refuse_any: {{ adguard_dns_refuse_any | to_json }}
  upstream_dns: {{ adguard_dns_upstream_dns | to_json }}
  upstream_dns_file: {{ adguard_dns_upstream_dns_file | to_json }}
  bootstrap_dns: {{ adguard_dns_bootstrap_dns | to_json }}
  fallback_dns: {{ adguard_dns_fallback_dns | to_json }}
  upstream_mode: {{ adguard_dns_upstream_mode | to_json }}
  fastest_timeout: {{ adguard_dns_fastest_timeout | to_json }}
  allowed_clients: {{ adguard_dns_allowed_clients | to_json }}
  disallowed_clients: {{ adguard_dns_disallowed_clients | to_json }}
  blocked_hosts: {{ adguard_dns_blocked_hosts | to_json }}
  trusted_proxies: {{ adguard_dns_trusted_proxies | to_json }}
  cache_enabled: {{ adguard_dns_cache_enabled | to_json }}
  cache_size: {{ adguard_dns_cache_size }}
  cache_ttl_min: {{ adguard_dns_cache_ttl_min }}
  cache_ttl_max: {{ adguard_dns_cache_ttl_max }}
  cache_optimistic: {{ adguard_dns_cache_optimistic | to_json }}
  cache_optimistic_answer_ttl: {{ adguard_dns_cache_optimistic_answer_ttl | to_json }}
  cache_optimistic_max_age: {{ adguard_dns_cache_optimistic_max_age | to_json }}
  bogus_nxdomain: {{ adguard_dns_bogus_nxdomain | to_json }}
