{% set monitoring_attach_remnawave_network = (enable_remnawave_panel | default(false) | bool) or (enable_remnashop | default(false) | bool) %}
services:
  prometheus:
    image: prom/prometheus:latest
    container_name: monitoring-prometheus
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ monitoring_prometheus_retention }}"
    ports:
      - "{{ monitoring_prometheus_port }}:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./public-status-rules.yml:/etc/prometheus/public-status-rules.yml:ro
      - prometheus-data:/prometheus
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}

  blackbox-exporter:
    image: {{ monitoring_blackbox_image }}
    container_name: monitoring-blackbox-exporter
    restart: unless-stopped
    command:
      - "--config.file=/etc/blackbox_exporter/config.yml"
    volumes:
      - ./blackbox.yml:/etc/blackbox_exporter/config.yml:ro
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}

{% if monitoring_remnawave_status_exporter_enabled | default(false) | bool %}
  remnawave-status-exporter:
    image: {{ monitoring_remnawave_status_exporter_image }}
    container_name: monitoring-remnawave-status-exporter
    restart: unless-stopped
    working_dir: /app
    command: ["node", "/app/server.mjs"]
    env_file:
      - ./remnawave-status-exporter.env
    volumes:
      - ./remnawave-status-exporter:/app:ro
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}
{% endif %}

{% if monitoring_xray_checker_enabled | default(false) | bool %}
  xray-checker:
    image: {{ monitoring_xray_checker_image }}
    container_name: monitoring-xray-checker
    restart: unless-stopped
    environment:
      - SUBSCRIPTION_URL={{ monitoring_xray_checker_subscription_url }}
      - SUBSCRIPTION_UPDATE=true
      - SUBSCRIPTION_UPDATE_INTERVAL={{ monitoring_xray_checker_subscription_update_interval }}
      - PROXY_CHECK_INTERVAL={{ monitoring_xray_checker_proxy_check_interval }}
      - PROXY_CHECK_METHOD={{ monitoring_xray_checker_proxy_check_method }}
      - WEB_PUBLIC={{ monitoring_xray_checker_web_public | ternary('true', 'false') }}
      - WEB_SHOW_DETAILS=false
      - METRICS_PROTECTED={{ monitoring_xray_checker_metrics_protected | ternary('true', 'false') }}
      - METRICS_PORT={{ monitoring_xray_checker_port }}
      - METRICS_HOST=0.0.0.0
      - METRICS_INSTANCE=remnawave
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}
{% endif %}

  grafana:
    image: grafana/grafana-oss:latest
    container_name: monitoring-grafana
    restart: unless-stopped
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
    user: "0:0"
{% endif %}
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    environment:
      - GF_SECURITY_ADMIN_USER={{ monitoring_grafana_admin_user }}
      - GF_SECURITY_ADMIN_PASSWORD={{ monitoring_grafana_admin_password }}
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
      - GF_SERVER_PROTOCOL=https
      - GF_SERVER_DOMAIN={{ monitoring_grafana_tls_domain }}
      - GF_SERVER_ROOT_URL=https://{{ monitoring_grafana_tls_domain }}:{{ monitoring_grafana_port }}
      - GF_SERVER_CERT_FILE=/etc/letsencrypt/live/{{ monitoring_grafana_tls_cert_domain | default(monitoring_grafana_tls_domain, true) }}/fullchain.pem
      - GF_SERVER_CERT_KEY=/etc/letsencrypt/live/{{ monitoring_grafana_tls_cert_domain | default(monitoring_grafana_tls_domain, true) }}/privkey.pem
{% endif %}
      - GF_AUTH_ANONYMOUS_ENABLED=false
      - GF_ANALYTICS_REPORTING_ENABLED=false
      - GF_ANALYTICS_CHECK_FOR_UPDATES=false
    volumes:
      - grafana-data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
      - /etc/letsencrypt:/etc/letsencrypt:ro
{% endif %}

{% if monitoring_public_grafana_enabled | default(false) | bool %}
  public-prometheus:
    image: prom/prometheus:latest
    container_name: {{ monitoring_public_prometheus_container_name }}
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ monitoring_prometheus_retention }}"
    volumes:
      - ./prometheus-public.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-public-data:/prometheus
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}

  public-grafana:
    image: {{ monitoring_public_grafana_image }}
    container_name: {{ monitoring_public_grafana_container_name }}
    restart: unless-stopped
    environment:
      - GF_SERVER_ROOT_URL={{ monitoring_public_grafana_root_url }}
      - GF_SERVER_SERVE_FROM_SUB_PATH=true
      - GF_AUTH_ANONYMOUS_ENABLED=true
      - GF_AUTH_ANONYMOUS_ORG_ROLE={{ monitoring_public_grafana_anonymous_role }}
      - GF_AUTH_DISABLE_LOGIN_FORM=true
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_ANALYTICS_REPORTING_ENABLED=false
      - GF_ANALYTICS_CHECK_FOR_UPDATES=false
      - GF_SECURITY_ALLOW_EMBEDDING=true
      - GF_EXPLORE_ENABLED=false
    volumes:
      - grafana-public-data:/var/lib/grafana
      - ./grafana-public/provisioning:/etc/grafana/provisioning:ro
      - ./grafana-public/dashboards:/var/lib/grafana/dashboards:ro
{% if monitoring_attach_remnawave_network %}
    networks:
      - default
      - remnawave-network
{% endif %}
{% endif %}

  loki:
    image: {{ monitoring_loki_image }}
    container_name: monitoring-loki
    restart: unless-stopped
    ports:
      - "{{ monitoring_loki_port }}:3100"
    command: -config.file=/etc/loki/config.yml
    volumes:
      - ./loki-config.yml:/etc/loki/config.yml:ro
      - loki-data:/loki

volumes:
  prometheus-data:
  prometheus-public-data:
  grafana-data:
  grafana-public-data:
  loki-data:

{% if monitoring_attach_remnawave_network %}
networks:
  remnawave-network:
    name: "{{ remnawave_network_name | default('remnawave-network') }}"
    external: true
{% endif %}
