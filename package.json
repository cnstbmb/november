{
  "name": "november",
  "version": "0.0.1",
  "description": "monorepo",
  "private": true,
  "main": "null",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/algorithms"
  ],
  "scripts": {
    "test:algorithms": "npm --workspace @november/algorithms test",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:backend": "npm --workspace november-server run build",
    "build:backend:docker": "npm --workspace november-server run build:docker:prod",
    "start:backend": "npm --workspace november-server run start",
    "lint:fix:backend": "npm --workspace november-server run lint:fix",
    "build:frontend": "npm --workspace frontend run build",
    "start:frontend": "npm --workspace frontend run start",
    "build:frontend:docker": "npm --workspace frontend run build:docker:prod",
    "watch:frontend": "npm --workspace frontend run watch",
    "lint:fix:frontend": "npm --workspace frontend run lint:fix",
    "prepare": "husky install",
    "build:prod": "tools/scripts/build_prod.sh",
    "build:prod:yc": "tools/scripts/build_prod_yc.sh",
    "build:prod:local:mac": "tools/scripts/build_prod_local_mac.sh",
    "ansible:bootstrap": "tools/ansible/bootstrap_private_vars.sh",
    "ansible:node-env": "tools/ansible/bootstrap_remnawave_node_env.sh",
    "ansible:topology": "tools/ansible/bootstrap_remnawave_topology.sh",
    "ansible:subscription-page": "tools/ansible/bootstrap_remnawave_subscription_page.sh",
    "remnawave:audit:sni-canary": "REMNAWAVE_MASTER_CANARY_PORT=4443 tools/ansible/remnawave/audit_master_sni_canary.sh",
    "remnawave:audit:sni-443": "REMNAWAVE_MASTER_SNI_PORT=443 tools/ansible/remnawave/audit_master_sni_canary.sh",
    "remnawave:audit:self-steal": "tools/ansible/remnawave/audit_self_steal.sh",
    "remnawave:apply:torrent-blocker": "node tools/ansible/remnawave/apply_torrent_blocker.mjs",
    "remnawave:apply:moscow-home-wifi": "node tools/ansible/remnawave/apply_moscow_home_wifi_9443.mjs",
    "ansible:warmup": "tools/ansible/warmup_prod_private.sh",
    "ansible:run": "tools/ansible/run_prod_private.sh",
    "ansible:run:check": "tools/ansible/run_prod_private.sh --check",
    "ansible:run:menu": "tools/ansible/run_prod_private.sh --menu",
    "ansible:base": "tools/ansible/run_prod_private.sh --playbook base",
    "ansible:base:check": "tools/ansible/run_prod_private.sh --playbook base --check",
    "ansible:master": "tools/ansible/run_prod_private.sh --playbook master",
    "ansible:master:fresh": "npm run ansible:base && npm run ansible:master",
    "ansible:master:check": "tools/ansible/run_prod_private.sh --playbook master --check",
    "ansible:workers": "tools/ansible/run_prod_private.sh --playbook workers --ask-become-pass",
    "ansible:workers:check": "tools/ansible/run_prod_private.sh --playbook workers --check --ask-become-pass",
    "ansible:site": "tools/ansible/run_prod_private.sh --playbook site",
    "ansible:site:check": "tools/ansible/run_prod_private.sh --playbook site --check",
    "ansible:monitoring": "tools/ansible/run_prod_private.sh --playbook monitoring",
    "ansible:monitoring:check": "tools/ansible/run_prod_private.sh --playbook monitoring --check",
    "ansible:remnawave-panel": "tools/ansible/run_prod_private.sh --playbook remnawave-panel",
    "ansible:remnawave-panel:check": "tools/ansible/run_prod_private.sh --playbook remnawave-panel --check",
    "nativeproxy:ansible": "tools/nativeproxy-ansible/run.sh",
    "nativeproxy:ansible:check": "tools/nativeproxy-ansible/run.sh --check",
    "remnashop:update": "ANSIBLE_LOCAL_TEMP=/tmp/ansible-local ANSIBLE_REMOTE_TEMP=/tmp/.ansible/tmp ansible -i .private/ansible/prod/hosts.yml master -b -m shell -a \"cd /opt/remnashop && docker compose pull remnashop remnashop-taskiq-worker remnashop-taskiq-scheduler && docker compose up -d\"",
    "landing:up": "docker compose -f deployments/landing-lite/docker-compose.yml up -d",
    "landing:down": "docker compose -f deployments/landing-lite/docker-compose.yml down",
    "landing:logs": "docker compose -f deployments/landing-lite/docker-compose.yml logs -f",
    "landing:open": "open http://localhost",
    "pg:docker:win": "docker run --rm -P -p 127.0.0.1:5432:5432 -v %cd%/pg-data:/var/lib/postgresql/data -d -e POSTGRES_PASSWORD=\"88005553535\" --name pg postgres:alpine",
    "pg:docker:linux": "docker run --rm -P -p 127.0.0.1:5432:5432 -v $(pwd)/pg-data:/var/lib/postgresql/data -d -e POSTGRES_PASSWORD=\"88005553535\" --name pg postgres:alpine"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cnstbmb/november.git"
  },
  "author": "cnstbmb@gmail.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cnstbmb/november/issues"
  },
  "homepage": "https://github.com/cnstbmb/november#readme",
  "devDependencies": {
    "@types/jest": "^29.2.2",
    "husky": "^7.0.4",
    "jest": "^29.3.0",
    "ts-jest": "^29.0.3"
  }
}
