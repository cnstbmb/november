global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_evaluation_interval }}

rule_files:
  - /etc/prometheus/public-status-rules.yml

{% set master_hosts = groups['master'] | default([]) %}
{% set worker_hosts = groups['workers'] | default([]) %}
{% set monitored_hosts = (master_hosts + worker_hosts) | unique %}
{% set master_host = (groups['master'] | default([]) | first) | default(inventory_hostname) %}
{% set master_node_target = monitoring_master_node_exporter_target | default('host.docker.internal:' ~ (monitoring_node_exporter_port | default(9100) | string), true) %}

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]
        labels:
          host: "{{ master_host }}"

  - job_name: nodes
    static_configs:
{% if monitoring_auto_discover_node_targets | default(true) | bool %}
{% for host in monitored_hosts %}
      - targets:
          - "{% if host == inventory_hostname %}{{ master_node_target }}{% else %}{{ hostvars[host].ansible_host | default(host) }}:{{ monitoring_node_exporter_port | default(9100) }}{% endif %}"
        labels:
          host: "{{ host }}"
          role: "{{ 'master' if host in (groups['master'] | default([])) else 'worker' }}"
{% endfor %}
{% else %}
      - targets:
{% for target in monitoring_node_targets | default([]) %}
          - "{{ target }}"
{% endfor %}
{% endif %}

{% if enable_remnawave_panel | default(false) | bool and monitoring_prometheus_scrape_remnawave_panel_metrics | default(true) | bool and remnawave_panel_metrics_user | default('') | length > 0 and remnawave_panel_metrics_pass | default('') | length > 0 %}
  - job_name: remnawave_panel
    metrics_path: {{ monitoring_remnawave_panel_metrics_path | default('/metrics') }}
    basic_auth:
      username: "{{ remnawave_panel_metrics_user }}"
      password: "{{ remnawave_panel_metrics_pass }}"
    static_configs:
      - targets:
          - "remnawave:{{ remnawave_panel_metrics_port | default(3001) }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
{% endif %}

{% if monitoring_remnawave_status_exporter_enabled | default(false) | bool %}
  - job_name: remnawave_nodes
    metrics_path: /metrics
    static_configs:
      - targets:
          - "remnawave-status-exporter:{{ monitoring_remnawave_status_exporter_port }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
{% endif %}

{% if monitoring_xray_checker_enabled | default(false) | bool %}
  - job_name: xray_checker
    metrics_path: /metrics
    static_configs:
      - targets:
          - "xray-checker:{{ monitoring_xray_checker_port }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
          service: "vpn"
{% endif %}

{% if monitoring_blackbox_enabled | default(true) | bool %}
{% set public_http_probes = [] %}
{% if remnawave_panel_domain | default('', true) | length > 0 %}
{% set _ = public_http_probes.append({'name': 'panel', 'url': 'https://' ~ remnawave_panel_domain}) %}
{% endif %}
{% if enable_remnawave_subscription_page | default(false) | bool and remnawave_subscription_page_domain | default('', true) | length > 0 %}
{% set _ = public_http_probes.append({'name': 'subscription', 'url': 'https://' ~ remnawave_subscription_page_domain}) %}
{% endif %}
{% if remnawave_panel_landing_server_names | default([]) | length > 0 %}
{% for landing_domain in remnawave_panel_landing_server_names %}
{% set _ = public_http_probes.append({'name': 'landing', 'url': 'https://' ~ landing_domain}) %}
{% endfor %}
{% endif %}
{% if enable_remnashop | default(false) | bool and remnashop_domain | default('', true) | length > 0 %}
{% set _ = public_http_probes.append({'name': 'bot', 'url': 'https://' ~ remnashop_domain}) %}
{% endif %}
{% if public_http_probes | length > 0 %}
  - job_name: public_http_services
    metrics_path: /probe
    params:
      module: [http_public_2xx]
    static_configs:
{% for public_probe in public_http_probes %}
      - targets:
          - "{{ public_probe.url }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
          service: "{{ public_probe.name }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "monitoring-blackbox-exporter:{{ monitoring_blackbox_port }}"
{% endif %}
{% endif %}

{% if enable_remnashop | default(false) | bool and monitoring_blackbox_enabled | default(true) | bool and monitoring_prometheus_scrape_remnashop_probes | default(true) | bool and remnashop_domain | default('', true) | length > 0 %}
  - job_name: remnashop_internal_http
    metrics_path: /probe
    params:
      module: [http_remnashop_internal]
    static_configs:
      - targets:
          - "{{ monitoring_remnashop_internal_probe_url }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
          service: "remnashop"
          probe: "internal"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "monitoring-blackbox-exporter:{{ monitoring_blackbox_port }}"

  - job_name: remnashop_webhook
    metrics_path: /probe
    params:
      module: [http_remnashop_webhook]
    static_configs:
      - targets:
          - "{{ monitoring_remnashop_webhook_probe_url }}"
        labels:
          host: "{{ master_host }}"
          role: "master"
          service: "remnashop"
          probe: "webhook"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "monitoring-blackbox-exporter:{{ monitoring_blackbox_port }}"
{% endif %}
