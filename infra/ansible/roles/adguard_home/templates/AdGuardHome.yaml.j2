  ignored: {{ adguard_querylog_ignored | to_json }}
  interval: {{ adguard_querylog_interval | to_json }}
  size_memory: {{ adguard_querylog_size_memory }}
  enabled: {{ adguard_querylog_enabled | to_json }}
  ignored_enabled: {{ adguard_querylog_ignored_enabled | to_json }}
  file_enabled: {{ adguard_querylog_file_enabled | to_json }}
