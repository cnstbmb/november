  rewrites_enabled: {{ adguard_filtering_rewrites_enabled | to_json }}
  parental_enabled: {{ adguard_filtering_parental_enabled | to_json }}
  safebrowsing_enabled: {{ adguard_filtering_safebrowsing_enabled | to_json }}
  protection_enabled: {{ adguard_filtering_protection_enabled | to_json }}
clients:
  runtime_sources: {{ adguard_clients_runtime_sources | to_json }}
  persistent: {{ adguard_clients_persistent | to_json }}
log:
  enabled: {{ adguard_log_enabled | to_json }}
  file: {{ adguard_log_file | to_json }}
  max_backups: {{ adguard_log_max_backups }}
  max_size: {{ adguard_log_max_size }}
  max_age: {{ adguard_log_max_age }}
  compress: {{ adguard_log_compress | to_json }}
  local_time: {{ adguard_log_local_time | to_json }}
  verbose: {{ adguard_log_verbose | to_json }}
os:
  group: {{ adguard_os_group | to_json }}
  user: {{ adguard_os_user | to_json }}
