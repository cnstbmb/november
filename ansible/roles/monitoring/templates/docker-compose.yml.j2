version: "3.8"
services:
  prometheus:
    image: prom/prometheus:latest
    container_name: monitoring-prometheus
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ monitoring_prometheus_retention }}"
    ports:
      - "{{ monitoring_prometheus_port }}:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus

  grafana:
    image: grafana/grafana-oss:latest
    container_name: monitoring-grafana
    restart: unless-stopped
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
    user: "0:0"
{% endif %}
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    environment:
      - GF_SECURITY_ADMIN_USER={{ monitoring_grafana_admin_user }}
      - GF_SECURITY_ADMIN_PASSWORD={{ monitoring_grafana_admin_password }}
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
      - GF_SERVER_PROTOCOL=https
      - GF_SERVER_DOMAIN={{ monitoring_grafana_tls_domain }}
      - GF_SERVER_ROOT_URL=https://{{ monitoring_grafana_tls_domain }}:{{ monitoring_grafana_port }}
      - GF_SERVER_CERT_FILE=/etc/letsencrypt/live/{{ monitoring_grafana_tls_cert_domain | default(monitoring_grafana_tls_domain, true) }}/fullchain.pem
      - GF_SERVER_CERT_KEY=/etc/letsencrypt/live/{{ monitoring_grafana_tls_cert_domain | default(monitoring_grafana_tls_domain, true) }}/privkey.pem
{% endif %}
    volumes:
      - grafana-data:/var/lib/grafana
{% if monitoring_grafana_tls_enabled | default(false) | bool %}
      - /etc/letsencrypt:/etc/letsencrypt:ro
{% endif %}

  loki:
    image: {{ monitoring_loki_image }}
    container_name: monitoring-loki
    restart: unless-stopped
    ports:
      - "{{ monitoring_loki_port }}:3100"
    command: -config.file=/etc/loki/config.yml
    volumes:
      - ./loki-config.yml:/etc/loki/config.yml:ro

  promtail:
    image: {{ monitoring_promtail_image }}
    container_name: monitoring-promtail
    restart: unless-stopped
    command: -config.file=/etc/promtail/config.yml
    volumes:
      - /var/log:/var/log:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /etc/hostname:/etc/hostname:ro
      - ./promtail-config.yml:/etc/promtail/config.yml:ro

  node_exporter:
    image: prom/node-exporter:latest
    container_name: monitoring-node-exporter
    restart: unless-stopped
    network_mode: host
    pid: host
    command:
      - "--path.rootfs=/host"
    volumes:
      - /:/host:ro,rslave

volumes:
  prometheus-data:
  grafana-data:
