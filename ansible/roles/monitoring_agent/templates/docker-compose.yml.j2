services:
  node_exporter:
    image: {{ monitoring_node_exporter_image }}
    container_name: {{ monitoring_node_exporter_container_name }}
    restart: unless-stopped
{% if monitoring_node_exporter_use_host_network | default(true) | bool %}
    network_mode: host
{% else %}
    expose:
      - "{{ monitoring_node_exporter_port | default(9100) }}"
    networks:
      - default
{% if monitoring_agent_attach_remnawave_network | default(false) | bool %}
      - remnawave-network
{% endif %}
{% endif %}
    command:
      - "--path.procfs=/host/proc"
      - "--path.rootfs=/rootfs"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc|run|snap)($|/)"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro,rslave

  promtail:
    image: {{ monitoring_promtail_image }}
    container_name: monitoring-promtail
    restart: unless-stopped
    command:
      - "-config.file=/etc/promtail/config.yml"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./promtail-config.yml:/etc/promtail/config.yml:ro
      - promtail-positions:/positions
      - /var/log:/var/log:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro

volumes:
  promtail-positions:

{% if monitoring_agent_attach_remnawave_network | default(false) | bool and not (monitoring_node_exporter_use_host_network | default(true) | bool) %}
networks:
  remnawave-network:
    name: "{{ monitoring_agent_network_name }}"
    external: true
{% endif %}
