    ids: {{ adguard_filtering_blocked_services_ids | to_json }}
  protection_disabled_until: {{ adguard_filtering_protection_disabled_until | to_json }}
  safe_search: {{ adguard_filtering_safe_search | to_json }}
  blocking_mode: {{ adguard_filtering_blocking_mode | to_json }}
  parental_block_host: {{ adguard_filtering_parental_block_host | to_json }}
