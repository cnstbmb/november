http:
  pprof:
    port: {{ adguard_pprof_port }}
    enabled: {{ adguard_pprof_enabled | to_json }}
  address: 0.0.0.0:{{ adguard_internal_web_port }}
  session_ttl: {{ adguard_session_ttl }}
users: {{ adguard_effective_users | default(adguard_users) | to_json }}
auth_attempts: {{ adguard_auth_attempts }}
block_auth_min: {{ adguard_block_auth_min }}
http_proxy: {{ adguard_http_proxy | to_json }}
language: {{ adguard_language | to_json }}
theme: {{ adguard_theme | to_json }}
dns:
