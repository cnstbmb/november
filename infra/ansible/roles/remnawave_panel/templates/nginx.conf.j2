{% for landing_server_name in remnawave_panel_landing_server_names_effective %}
{{ render_xhttp_locations(landing_server_name) }}
{% endfor %}
{{ render_public_status_locations() }}
{{ deny_hidden_files() }}
    location / {
        try_files $uri $uri/ /index.html;
